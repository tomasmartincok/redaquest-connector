#, php-format
msgid "%s was updated."
msgstr "%s byl aktualizován."

#: redaquest-connector.php:1073
msgid "Connect = schedule social posts from the editor. API key = sync content and products."
msgstr "Connect = plánování příspěvků z editoru. API klíč = synchronizace obsahu a produktů."

