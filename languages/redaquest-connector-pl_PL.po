#: src/index.js:742 src/index.js:758
msgid "Add a topic or a post title first."
msgstr "Najpierw dodaj temat lub tytuł wpisu."

#: src/index.js:1031 src/index.js:1146
msgid "Continue"
msgstr "Dalej"

#: src/index.js:1039
msgid ""
"Pick who you’re writing for, and optionally add your own angle. It is all "
"optional, and it improves quality."
msgstr ""
"Wybierz, dla kogo piszesz, i opcjonalnie dodaj własny punkt widzenia. "
"Wszystko jest opcjonalne i poprawia jakość."

#: src/index.js:1041
