#. Plugin Name of the plugin
#: redaquest-connector.php
#: redaquest-connector.php:1023
#: redaquest-connector.php:1024
#: redaquest-connector.php:1068
msgid "Redaquest Connector"
msgstr ""

#. Plugin URI of the plugin
#: redaquest-connector.php
msgid "https://github.com/tomasmartincok/redaquest-connector"
msgstr ""

#. Description of the plugin
#: redaquest-connector.php
msgid "Connect WordPress and WooCommerce to RedaQuest: sync content and products, and schedule social posts straight from the article editor."
msgstr "Prepojí WordPress a WooCommerce s RedaQuestom: synchronizuje obsah a produkty a plánuje príspevky na sociálne siete priamo z editora článku."

#. Author of the plugin
#: redaquest-connector.php
msgid "RedaQuest"
msgstr ""

#. Author URI of the plugin
#: redaquest-connector.php
msgid "https://redaquest.com"
msgstr ""

#: includes/class-redaquest-connect.php:101
msgid "Invalid or expired connection state. Please try again."
msgstr "Neplatný alebo expirovaný stav pripojenia. Skús to znova."

#: includes/class-redaquest-connect.php:119
msgid "Could not reach RedaQuest. Please try again."
msgstr "Nepodarilo sa spojiť s RedaQuestom. Skús to znova."

#: includes/class-redaquest-connect.php:127
msgid "The connection could not be completed. Please try again from RedaQuest."
msgstr "Pripojenie sa nepodarilo dokončiť. Skús to znova z RedaQuestu."

#: includes/class-redaquest-connect.php:143
msgid "You do not have permission to do this."
msgstr "Na túto akciu nemáš oprávnenie."

#: includes/class-redaquest-connect.php:179
msgid "Schedule social posts (RedaQuest Connect)"
msgstr "Plánovanie príspevkov na siete (RedaQuest Connect)"

#: includes/class-redaquest-connect.php:182
msgid "Your site is connected to RedaQuest."
msgstr "Web je pripojený k RedaQuestu."

#: includes/class-redaquest-connect.php:185
msgid "The RedaQuest connection was removed."
msgstr "Pripojenie k RedaQuestu bolo zrušené."

#: includes/class-redaquest-connect.php:189
msgid "Connected"
msgstr "Pripojené"

#: includes/class-redaquest-connect.php:191
msgid "Workspace ID:"
msgstr "ID workspace:"

#. translators: %s: date and time the site was connected.
#: includes/class-redaquest-connect.php:198
#, php-format
msgid "Connected: %s"
msgstr "Pripojené: %s"

#: includes/class-redaquest-connect.php:204
msgid "Disconnect"
msgstr "Odpojiť"

#: includes/class-redaquest-connect.php:208
msgid "Connect this site so you can generate and schedule social posts from the article editor. You will be redirected to RedaQuest to approve and pick a workspace; a RedaQuest account is required."
msgstr "Pripoj tento web, aby si mohol generovať a plánovať príspevky na siete priamo z editora článku. Presmerujeme ťa do RedaQuestu, kde pripojenie schváliš a vyberieš workspace. Potrebuješ RedaQuest účet."

#: includes/class-redaquest-connect.php:211
#: src/index.js:444
msgid "Connect RedaQuest"
msgstr "Pripojiť RedaQuest"

#: includes/class-redaquest-proxy.php:65
#: src/index.js:443
msgid "This site is not connected to RedaQuest."
msgstr "Tento web nie je pripojený k RedaQuestu."

#: includes/class-redaquest-proxy.php:78
msgid "Could not reach RedaQuest."
msgstr "Nepodarilo sa spojiť s RedaQuestom."

#: includes/class-redaquest-proxy.php:83
msgid "The connection expired. Please reconnect your site."
msgstr "Pripojenie vypršalo. Pripoj web znova."

#: includes/class-redaquest-proxy.php:95
msgid "RedaQuest returned an error."
msgstr "RedaQuest vrátil chybu."

#: includes/class-redaquest-proxy.php:104
#: includes/class-redaquest-proxy.php:142
msgid "Missing article (title and content)."
msgstr "Chýba článok (titulok a obsah)."

#: includes/class-redaquest-proxy.php:134
#: src/index.js:414
msgid "Generation failed."
msgstr "Generovanie zlyhalo."

#: includes/class-redaquest-proxy.php:181
#: src/index.js:299
msgid "Image generation failed."
msgstr "Generovanie obrázka zlyhalo."

#: includes/class-redaquest-proxy.php:270
msgid "Could not save the image."
msgstr "Nepodarilo sa uložiť obrázok."

#: includes/class-redaquest-proxy.php:346
#: src/index.js:198
msgid "Scheduling failed."
msgstr "Plánovanie zlyhalo."

#: redaquest-connector.php:194
msgid "API key is missing. Add the API key from your RedaQuest integration in the plugin settings."
msgstr "Chýba API kľúč. Vlož API kľúč z RedaQuest integrácie do nastavení pluginu."

#: redaquest-connector.php:200
msgid "No API key is configured in the plugin settings. Go to Settings → Redaquest Connector and add your API key."
msgstr "API kľúč nie je nakonfigurovaný v nastaveniach pluginu. Prejdi do Nastavenia → Redaquest Connector a vlož API kľúč."

#: redaquest-connector.php:204
msgid "Invalid API key. Check that you pasted the correct API key from your RedaQuest integration."
msgstr "Neplatný API kľúč. Skontroluj, či si vložil správny API kľúč z RedaQuest integrácie."

#: redaquest-connector.php:215
msgid "Writing is disabled. Enable content writing in the plugin settings."
msgstr "Zápis je vypnutý. Povoľ zápis obsahu v nastaveniach pluginu."

#: redaquest-connector.php:264
msgid "Connection successful."
msgstr "Pripojenie úspešné."

